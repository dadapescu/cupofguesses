rules_version = '2';

// Reguli pentru "Pariul din birou".
// Permit citire/scriere doar in interiorul camerelor rooms/*.
// Suficient pentru un joc intre colegi (bazat pe incredere).
// Pentru extra siguranta, poti pune o data limita dupa care nimeni
// nu mai scrie: schimba data din linia 'allow write' de mai jos.

service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{room}/{document=**} {
      allow read: if true;
      allow write: if request.time < timestamp.date(2026, 8, 1);
    }
  }
}
